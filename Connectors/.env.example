# Rename to .env in your project root (prisma init already created a .env — edit that).
# Replace [PASSWORD] with your Supabase database password
# (Supabase → Settings → Database → Database password; reset there if lost).

# DATABASE_URL = DIRECT connection (port 5432).
# Prisma 7 CLI (db pull / migrate) reads this via prisma.config.ts.
DATABASE_URL="postgresql://postgres.yhhvkvacykksopurzpmj:[PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"

# DATABASE_URL_POOLED = POOLED connection (port 6543) — for the app at RUNTIME
# (Prisma Client 7 driver adapter + supabase-js). Not needed for db pull.
DATABASE_URL_POOLED="postgresql://postgres.yhhvkvacykksopurzpmj:[PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
